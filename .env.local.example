# ─── Autenticação (obrigatório) ────────────────────────────────────────────
# SESSION_SECRET deve ter pelo menos 32 caracteres — usado para assinar os tokens JWT
SESSION_SECRET=troque-por-uma-string-aleatoria-com-32-caracteres-ou-mais

# Login do administrador (acesso total, inclui /admin)
ADMIN_EMAIL=adm@accoelho.com.br
ADMIN_PASSWORD=123456y@

# Login do cliente (acesso somente ao /dashboard)
CLIENT_EMAIL=adm@accoelho.com.br
CLIENT_PASSWORD=123456y@

# ─── Gemini AI (opcional — para análise com IA) ────────────────────────────
# Obter gratuitamente em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_aqui

# ─── Planilha de dados (opcional — ver GOOGLE_SHEETS_SETUP.md) ────────────────
# 1 único Google Sheets com abas: Google_Ads, Meta_Ads (VTEX e GA4 ainda não conectadas)
# Compartilhamento: "Qualquer pessoa com o link" → Leitor
# Use a URL normal de edição da planilha (https://docs.google.com/spreadsheets/d/SEU_ID/edit)
# Se deixar em branco, o código usa a URL fixa definida em lib/sheets.ts (DEFAULT_MASTER_URL)
SHEETS_MASTER_URL=https://docs.google.com/spreadsheets/d/SEU_ID/edit
